# Local secrets and env
.env
.env.*
!.env.example

# Python
*.pyc
__pycache__/

# macOS
.DS_Store

# ---------------------------------------------------------------------------
# Pipeline runtime — regenerated by ./pipeline/*.sh (do not commit)
# ---------------------------------------------------------------------------

# Staging: mapped JSONL, idempotency log, cron logs, temp files
staging/**
!staging/.gitkeep

# Incoming: Parquet synced from MinIO or built locally
incoming/**
!incoming/.gitkeep

# Parquet binaries (built by setup_minio.sh / learning/csv_to_parquet.py)
parquet/*.parquet
parquet/mapped_*.jsonl

# EDA outputs (sz_snapshot, sz_audit)
truthset_snapshot.json
truthset_snapshot.csv
truthset_audit.json
truthset_audit.csv
actual_audit.json
actual_audit.csv

# sz_explorer ad-hoc exports
*_export.jsonl
snapshots.json
